include CMakeLists.txt
include README.md
include LICENSE.md
include setup.py
include pyproject.toml
include MANIFEST.in

recursive-include src *.cpp *.hpp *.h *.py
recursive-include ext/zlib *.c *.h CMakeLists.txt *.cmake
recursive-include ext/pybind11 *.h *.hpp *.cpp *.cmake CMakeLists.txt
recursive-include ext/eigen *.h *.hpp *.cmake CMakeLists.txt
recursive-include ext/doctest *.h CMakeLists.txt

global-exclude *.pyc *.pyo __pycache__
